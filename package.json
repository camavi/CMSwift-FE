{
  "name": "cmswift",
  "private": true,
  "version": "1.0.17",
  "description": "CMSwift UI + reactive runtime framework",
  "author": "Carlos Malleux",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:cms": "node tools/build-cms.mjs",
    "build:ui:assets": "node tools/build-ui-assets.mjs",
    "build:ui:css": "node tools/build-ui-css.mjs",
    "build:ui": "npm run build:ui:assets && npm run build:ui:css && node tools/build-ui.mjs",
    "build:cmswift": "node tools/build-cmswift.mjs",
    "build:runtime": "npm run build:cms && npm run build:ui && npm run build:cmswift",
    "preview": "vite preview",
    "test": "node --test tests/*.test.mjs",
    "test:browser": "node --test tests/browser/*.test.mjs",
    "gen:ui-dts": "node cms-dev/generate-ui-dts.mjs",
    "gen:ui-dts:watch": "node cms-dev/generate-ui-dts.mjs --watch"
  },
  "devDependencies": {
    "vite": "^7.2.4",
    "express": "^5.2.1"
  },
  "dependencies": {}
}
